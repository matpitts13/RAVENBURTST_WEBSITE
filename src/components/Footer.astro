---
const year = new Date().getFullYear()
---
<footer class="border-t border-rb-border mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xl font-serif text-rb-accent italic">𝕽</span>
          <span class="font-semibold text-rb-text">Ravenburst</span>
        </div>
        <p class="text-rb-muted text-sm leading-relaxed">
          AI-powered writing environment for serious authors.
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-rb-text mb-3">Product</h4>
        <ul class="space-y-2 text-sm text-rb-muted">
          <li><a href="/features" class="hover:text-rb-text transition-colors">Features</a></li>
          <li><a href="/pricing" class="hover:text-rb-text transition-colors">Pricing</a></li>
          <li><a href="/download" class="hover:text-rb-text transition-colors">Download</a></li>
          <li><a href="/changelog" class="hover:text-rb-text transition-colors">Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-rb-text mb-3">Company</h4>
        <ul class="space-y-2 text-sm text-rb-muted">
          <li><a href="/about" class="hover:text-rb-text transition-colors">About</a></li>
          <li><a href="/support" class="hover:text-rb-text transition-colors">Support</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-rb-text mb-3">Legal</h4>
        <ul class="space-y-2 text-sm text-rb-muted">
          <li><a href="/legal/privacy" class="hover:text-rb-text transition-colors">Privacy Policy</a></li>
          <li><a href="/legal/terms" class="hover:text-rb-text transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-rb-border pt-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-rb-muted text-sm">© {year} Ravenburst. All rights reserved.</p>
      <p class="text-rb-muted text-xs">
        AI that edits. Never writes. <span class="text-rb-accent">Your story. Your words.</span>
      </p>
    </div>
  </div>
</footer>
