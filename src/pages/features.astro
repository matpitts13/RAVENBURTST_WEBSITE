---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
const features = [
  { icon: '✍️', title: 'Rich Text Editor', body: 'Full TipTap editor with format bar, bubble menu on selection, heading styles, lists, tables, and more. No autocorrect. No autocomplete. Ever.' },
  { icon: '📁', title: 'Full Project Structure', body: 'Chapters, scenes, parts, characters, places, reference materials, front matter, templates, and AI reports — all in one portable file.' },
  { icon: '🔍', title: 'Continuity Check', body: 'AI scans your manuscript for character inconsistencies, timeline issues, location logic errors, and name variants. Reports saved with timestamps.' },
  { icon: '📖', title: 'Writing Coach', body: 'Structural feedback in the form of questions — not rewrites. The coach asks what a good editor would ask. Your answers stay yours.' },
  { icon: '🔬', title: 'Reference Assistant', body: 'Ask factual background research questions. Answers are clearly marked when uncertain, saved to your Reference section, and never invented.' },
  { icon: '📚', title: 'Story Bible', body: 'Extract characters, locations, objects, and events from your chapters automatically. Build a consistency reference as you write.' },
  { icon: '🌙', title: 'Local AI — Free Forever', body: 'Ollama is bundled with Ravenburst. No account needed. No API key. The AI runs on your machine. Optionally upgrade to Claude with your own key.' },
  { icon: '📊', title: 'Word Count Everything', body: 'Per-document, per-project, per-selection. Visible in the status bar always. Target word count progress bar. Breakdown by chapter.' },
  { icon: '📸', title: 'Snapshot History', body: 'Ctrl+Shift+S saves a named snapshot of any document. Browse, preview, and restore at any time. Nothing is ever truly deleted.' },
  { icon: '🔎', title: 'Find & Replace', body: 'In-document find bar with regex support. Project-wide search across all documents. Replace single or all instances.' },
  { icon: '🎓', title: 'Academic Formats', body: 'APA 7th and MLA 9th export with proper formatting. User-editable format specs — update to APA 8th when it ships without waiting for an app update.' },
  { icon: '🌙', title: 'Dark & Light Mode', body: 'Three theme options: dark, light, or follow your OS. Toggle in the status bar. Smooth transitions.' },
]
---
<Base title="Features" description="Everything a serious author needs. Nothing they don't.">
  <Nav />
  <main class="pt-32 pb-20 px-6 max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">Built for writers who mean it.</h1>
      <p class="text-rb-muted text-xl max-w-xl mx-auto">Everything you need. Nothing you don't. No upsells, no add-ons, no feature flags.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map(f => (
        <div class="bg-rb-surface border border-rb-border rounded-xl p-6">
          <div class="text-2xl mb-3">{f.icon}</div>
          <h3 class="font-semibold text-rb-text mb-2">{f.title}</h3>
          <p class="text-rb-muted text-sm leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </main>
  <Footer />
</Base>
