---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
---
<Base title="Terms of Service">
  <Nav />
  <main class="pt-32 pb-20 px-6 max-w-2xl mx-auto">
    <h1 class="text-4xl font-serif font-bold mb-8">Terms of Service</h1>
    <p class="text-rb-muted text-sm mb-8">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    <div class="space-y-6 text-rb-muted leading-relaxed text-sm">
      <p><strong class="text-rb-text">Plain language summary:</strong> Buy the app, use it honestly, don't redistribute it, your writing is yours.</p>
      <h2 class="text-rb-text text-xl font-semibold">License</h2>
      <p>Purchasing Ravenburst grants you a personal, non-transferable license to install and use the software on up to 3 devices. You may not redistribute, resell, or reverse-engineer the application.</p>
      <h2 class="text-rb-text text-xl font-semibold">Your content</h2>
      <p>Everything you write in Ravenburst belongs entirely to you. We claim no rights to your content. Your files are stored locally on your device.</p>
      <h2 class="text-rb-text text-xl font-semibold">Refunds</h2>
      <p>We offer a full refund within 30 days of purchase, no questions asked. Email support@ravenburst.com.</p>
      <h2 class="text-rb-text text-xl font-semibold">Warranty disclaimer</h2>
      <p>Ravenburst is provided "as is." We do our best to make it reliable, but we are not liable for data loss. Back up your .ravenburst files regularly.</p>
      <h2 class="text-rb-text text-xl font-semibold">Contact</h2>
      <p><a href="mailto:support@ravenburst.com" class="text-rb-accent">support@ravenburst.com</a></p>
    </div>
  </main>
  <Footer />
</Base>
