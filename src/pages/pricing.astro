---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---
<Base title="Pricing" description="Buy once, own it. No subscription. Free updates through the next major version.">
  <Nav />
  <main class="pt-32 pb-20 px-6 max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">Simple, honest pricing.</h1>
      <p class="text-rb-muted text-xl max-w-xl mx-auto">Buy once. Own it forever. No subscription. No monthly fees.</p>
    </div>

    <!-- Main pricing card -->
    <div class="max-w-md mx-auto bg-rb-surface border-2 border-rb-accent rounded-2xl p-8 mb-12 text-center">
      <div class="text-rb-muted text-sm uppercase tracking-widest mb-2">Ravenburst</div>
      <div class="text-5xl font-bold text-rb-text mb-2">$39</div>
      <div class="text-rb-muted text-sm mb-8">one-time · no subscription · ever</div>
      <ul class="text-left space-y-3 mb-8 text-sm text-rb-muted">
        {[
          'Unlimited projects',
          'All export formats (Manuscript, Screenplay, EPUB, Academic, Children\'s Book, and more)',
          'AI editorial tools (Continuity Check, Writing Coach, Reference Assistant)',
          'Offline-first — works without internet',
          'Free updates through v2',
          'Windows, macOS, and Linux',
        ].map(f => (
          <li class="flex items-start gap-3">
            <span class="text-rb-green mt-0.5">✓</span>
            <span>{f}</span>
          </li>
        ))}
      </ul>
      <a href="/download"
        class="block bg-rb-accent hover:bg-rb-accent-hv text-white py-4 rounded-xl font-semibold transition-colors mb-3">
        Buy Now
      </a>
      <a href="/download" class="text-rb-muted text-sm hover:text-rb-text transition-colors">
        Try free for 7 days first →
      </a>
    </div>

    <!-- Upgrade path -->
    <div class="bg-rb-surface border border-rb-border rounded-2xl p-8 mb-8">
      <h2 class="text-xl font-serif font-semibold mb-4">How upgrades work</h2>
      <div class="grid md:grid-cols-3 gap-6 text-sm text-rb-muted">
        <div>
          <div class="text-rb-text font-semibold mb-2">v1 buyers</div>
          Free upgrade to v2 included. All v1 and v2 patches are always free.
        </div>
        <div>
          <div class="text-rb-text font-semibold mb-2">Future major versions</div>
          ~$10–15 upgrade price when v3+ ships. Never forced — v1 keeps working.
        </div>
        <div>
          <div class="text-rb-text font-semibold mb-2">Kickstarter backers</div>
          Free through v3 + all patches as a thank-you for supporting early.
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="space-y-4">
      <h2 class="text-2xl font-serif font-semibold mb-6">Common questions</h2>
      {[
        ['Do I need an internet connection?', 'Only for the 7-day trial registration, activating your license key, and if you use the Claude AI option. Everything else — writing, editing, exporting — works completely offline.'],
        ['How many computers can I use it on?', 'Up to 3 devices on one license. Use Help → Deactivate License to free up a slot if you change machines.'],
        ['What AI does it use?', 'Ollama (local, free, bundled with the app) by default. Optionally your own Claude API key for more powerful analysis. Either way, the AI acts as an editor only — it never writes prose for you. Claude API usage is billed directly by Anthropic at their standard rates. Ravenburst has no affiliation with Anthropic and receives nothing from your usage — your key, your bill, your data.'],
        ['Can I get a refund?', 'Yes — within 30 days, no questions asked. Email support@ravenburst.com. Upon refund, your activation code will be deactivated and the app will revert to an expired state.'],
        ['Is there a student discount?', "Not yet — but the $39 one-time price is intentionally affordable. We'd rather you own it than feel like you're renting it."],
      ].map(([q, a]) => (
        <details class="bg-rb-surface border border-rb-border rounded-xl p-5 group">
          <summary class="font-medium text-rb-text cursor-pointer list-none flex justify-between items-center">
            {q}
            <span class="text-rb-muted group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <p class="mt-3 text-rb-muted text-sm leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </main>
  <Footer />
</Base>
